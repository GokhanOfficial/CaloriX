# Supabase Configuration
# For hosted Supabase, use your project URL.
# For Docker development with the local Supabase stack, use http://localhost:54321.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Docker / Local Supabase Configuration (development only)
# Required when running the Supabase CLI inside Docker so bind mounts resolve on the host.
PROJECT_ROOT="/CaloriX-v2"
SUPABASE_ACCESS_TOKEN=""

# AI Configuration (Pollinations AI - Free)
OPENAI_API_KEY="dummy-key"
OPENAI_BASE_URL="https://gen.pollinations.ai/v1"
OPENAI_MODEL="openai"

# Notification Configuration (Optional)
RESEND_API_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
